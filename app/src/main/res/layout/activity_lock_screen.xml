<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#0a0a0f">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔒 WhatsApp נעול"
        android:textColor="#ff4444"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="קוד ילד:"
        android:textColor="#888899"
        android:textSize="13sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/displayCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="----"
        android:textColor="#00ff88"
        android:textSize="40sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:background="@drawable/input_bg"
        android:padding="14dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/timerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#888899"
        android:textSize="13sp"
        android:layout_marginBottom="32dp" />

    <EditText
        android:id="@+id/unlockInput"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="הכנס קוד פתיחה (6 ספרות)"
        android:textColorHint="#2a2a3e"
        android:textColor="#e0e0e0"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:inputType="numberPassword"
        android:background="@drawable/input_bg"
        android:padding="12dp"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/errorText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#ff4444"
        android:textSize="13sp"
        android:layout_marginBottom="16dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/unlockBtn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="פתח"
        android:textColor="#00ff88"
        android:background="@drawable/btn_outline_green" />

</LinearLayout>
